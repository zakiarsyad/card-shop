# ─────────────────────────────────────────────────────────────────────────
# Stripe Checkout Lab — environment variables (TEST MODE ONLY)
#
# Copy to `.env` and fill in your own Stripe *test* values:
#   cp .env.example .env
#
# Never use live keys. Never commit `.env` (it is gitignored).
# ─────────────────────────────────────────────────────────────────────────

# Publishable test key (pk_test_…). Exposed to the client — this is expected.
PUBLIC_STRIPE_KEY=pk_test_REPLACE_ME

# Secret test key (sk_test_…). Server-side only. NEVER expose to the client.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Webhook signing secret (whsec_…).
# Local: run `stripe listen --forward-to localhost:8888/.netlify/functions/stripe-webhook`
#        and copy the printed secret here.
# Prod:  from the Stripe Dashboard webhook endpoint you register.
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Stripe test Price IDs. Create one Product with two Prices in the dashboard:
#   - a one-time price of $49.00  → PRICE_ONE_TIME
#   - a recurring price of $9.00/mo → PRICE_SUBSCRIPTION
PRICE_ONE_TIME=price_REPLACE_ME
PRICE_SUBSCRIPTION=price_REPLACE_ME

# Xendit (test mode) — Components flow
XENDIT_SECRET_KEY=xnd_development_...
XENDIT_CALLBACK_TOKEN=...

---
// Self-hosted font (no external request, no layout shift). One variable family
// — Inter — used across the whole UI, the Stripe-vibe sans. See ADR-0006.
import "@fontsource-variable/inter";
import "../styles/global.css";
import { BRAND } from "../lib/brand";

interface Props {
  title?: string;
  description?: string;
  /**
   * Preconnect to Stripe only on pages that will load Stripe.js, so we don't
   * pay the connection cost on pages that never touch it.
   */
  preconnectStripe?: boolean;
}

const {
  title = BRAND.name,
  description = BRAND.description,
  preconnectStripe = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, BRAND.url).href;

// Structured data for search / answer engines: what this is, who made it, and
// where the source lives. Kept honest — a demo, with the repo as sameAs.
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: BRAND.name,
  url: BRAND.url,
  description: BRAND.description,
  inLanguage: "en",
  author: { "@type": "Person", name: BRAND.author },
  sameAs: [BRAND.repo],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={BRAND.author} />
    <link rel="canonical" href={canonical} />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#f6f9fc" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={BRAND.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />

    {
      preconnectStripe && (
        <>
          <link rel="preconnect" href="https://js.stripe.com" />
          <link rel="preconnect" href="https://api.stripe.com" />
        </>
      )
    }

    <meta name="generator" content={Astro.generator} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
  </head>
  <body>
    <slot />
  </body>
</html>

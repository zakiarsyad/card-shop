---
// The pitch for the Xendit demo: what it is and what it demonstrates.
const points = [
  "Components SDK — our own UI, card data stays with Xendit",
  "Tamper-proof pricing — set on the server, never the browser",
  "Webhook-driven fulfillment, verified by callback token",
  "Card payments with inline 3-D Secure",
  "One-time or subscription — both on Xendit Payment Sessions",
];
---

<div class="intro">
  <h1 id="demo-title">A Xendit checkout</h1>
  <p class="sub">
    The same product, on Xendit's Components SDK — one-time or subscription, in IDR. Under the hood:
  </p>
  <ul class="points">
    {points.map((p) => <li>{p}</li>)}
  </ul>
  <p class="hint">
    In test mode, the card form's “Simulate scenario” button fills a test card for you.
  </p>
</div>

<style>
  h1 {
    font-size: clamp(1.75rem, 4vw, 2.375rem);
    font-weight: 680;
    letter-spacing: -0.03em;
    margin: 0 0 0.875rem;
  }
  .sub {
    margin: 0 0 1.5rem;
    font-size: var(--text-base);
    line-height: 1.55;
    color: var(--color-ink-700);
    max-width: 44ch;
  }
  .points {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.55rem;
    max-width: 46ch;
  }
  .points li {
    position: relative;
    padding-left: 1.5rem;
    font-size: var(--text-sm);
    line-height: 1.45;
    color: var(--color-ink-700);
  }
  .points li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.45em;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 2px;
    background: var(--color-accent);
  }
  .hint {
    margin: 1.25rem 0 0;
    font-size: var(--text-xs);
    color: var(--color-ink-500);
    max-width: 46ch;
    line-height: 1.5;
  }
</style>

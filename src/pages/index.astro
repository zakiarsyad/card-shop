---
// Landing hub: one product, sold the same two ways, built once per payment
// provider. Each provider is its own subpath (/stripe, /adyen, /xendit) sharing
// the design system and domain core — see docs/decisions/ADR-0009.
import Layout from "../layouts/Layout.astro";
import { BRAND } from "../lib/brand";

const providers = [
  {
    name: "Stripe",
    note: "Payment Element · one-time & subscription",
    href: "/stripe",
    ready: true,
  },
  { name: "Xendit", note: "Components · one-time card", href: "/xendit", ready: true },
  { name: "Adyen", note: "Drop-in · coming soon", href: "", ready: false },
];
---

<Layout
  title={`${BRAND.name} — payment provider demos`}
  description="One product, sold one-time or by subscription — built once per payment provider, each in its own brand, with the same engineering rigor."
>
  <main class="page">
    <header class="intro">
      <h1>Checkout demos</h1>
      <p class="sub">
        One product, sold one-time or by subscription — built once per payment
        provider. Same rigor, each in its own brand.
      </p>
    </header>

    <ul class="providers">
      {
        providers.map((p) =>
          p.ready ? (
            <li>
              <a class="provider" href={p.href}>
                <span class="provider__name">{p.name}</span>
                <span class="provider__note">{p.note}</span>
                <span class="provider__go">Open demo →</span>
              </a>
            </li>
          ) : (
            <li>
              <div class="provider provider--soon" aria-disabled="true">
                <span class="provider__name">{p.name}</span>
                <span class="provider__note">{p.note}</span>
                <span class="provider__go">Coming soon</span>
              </div>
            </li>
          ),
        )
      }
    </ul>
  </main>
</Layout>

<style>
  .page {
    min-height: 100dvh;
    max-width: 720px;
    margin-inline: auto;
    padding: clamp(2rem, 8vw, 5rem) clamp(1rem, 4vw, 2rem);
    display: flex;
    flex-direction: column;
    gap: clamp(1.75rem, 4vw, 2.5rem);
    justify-content: center;
  }
  h1 {
    font-size: clamp(1.875rem, 5vw, 2.5rem);
    font-weight: 680;
    letter-spacing: -0.03em;
    margin: 0 0 0.75rem;
  }
  .sub {
    margin: 0;
    font-size: var(--text-base);
    line-height: 1.55;
    color: var(--color-ink-700);
    max-width: 46ch;
  }
  .providers {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }
  .provider {
    display: grid;
    gap: 0.2rem;
    padding: 1.1rem 1.25rem;
    background: var(--color-paper);
    border: 1px solid var(--color-ink-200);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition:
      border-color 0.15s ease,
      box-shadow 0.15s ease;
  }
  a.provider:hover {
    border-color: var(--color-accent);
    box-shadow: 0 1px 2px rgb(10 37 64 / 0.04), 0 10px 28px -14px rgb(10 37 64 / 0.18);
  }
  .provider__name {
    font-weight: 640;
    font-size: var(--text-base);
    color: var(--color-ink-900);
  }
  .provider__note {
    font-size: var(--text-sm);
    color: var(--color-ink-500);
  }
  .provider__go {
    margin-top: 0.4rem;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-accent-strong);
  }
  .provider--soon {
    opacity: 0.6;
  }
  .provider--soon .provider__go {
    color: var(--color-ink-500);
  }
</style>

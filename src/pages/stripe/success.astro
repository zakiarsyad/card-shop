---
import Layout from "../../layouts/Layout.astro";
import { BRAND } from "../../lib/brand";
---

<Layout preconnectStripe provider="stripe" title={`Payment status — ${BRAND.name}`}>
  <main class="page">
    <section class="card" aria-live="polite">
      <div class="icon" id="icon" data-tone="pending" aria-hidden="true"></div>
      <h1 id="title"></h1>
      <p class="message" id="message"></p>

      <p class="subnote" id="subnote" hidden></p>

      <p class="note" id="note" hidden>
        Your payment is confirmed. We'll fulfill the order on our server once we
        receive Stripe's webhook — a reliable server-to-server signal.
      </p>

      <!-- Live indicator: sits just above the button; spins while waiting and
           flips to confirmed when Stripe's webhook for this payment arrives. -->
      <div class="webhook" id="webhook" data-state="idle" hidden>
        <span class="webhook__dot" aria-hidden="true"></span>
        <span class="webhook__text" id="webhook-text"></span>
      </div>
      <p class="webhook__caption" id="webhook-caption" hidden>
        Shown only for this demo — customers never see this.
      </p>

      <a class="btn" href="/stripe">Back to checkout</a>
    </section>
  </main>

  <script>
    import { renderSuccess } from "../../scripts/stripe/success";
    renderSuccess();
  </script>
</Layout>

<style>
  .page {
    min-height: 100dvh;
    display: grid;
    place-items: center;
    padding: clamp(1rem, 4vw, 2.5rem);
  }
  .card {
    width: 100%;
    max-width: 440px;
    background: var(--color-paper);
    border: 1px solid var(--color-ink-200);
    border-radius: var(--radius-lg);
    padding: clamp(1.75rem, 5vw, 2.5rem);
    text-align: center;
    box-shadow:
      0 1px 2px rgb(12 10 9 / 0.04),
      0 12px 32px -12px rgb(12 10 9 / 0.12);
    /* Invisible until JS has painted the resolved state, then fades in fully
       formed — avoids the elements popping in one by one (layout jump). */
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .card.ready {
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .card {
      transition: none;
    }
  }
  .icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    margin: 0 auto 1.25rem;
    display: grid;
    place-items: center;
    background: var(--color-accent-soft);
  }
  .icon::after {
    content: "";
    display: block;
  }
  .icon[data-tone="succeeded"] {
    background: var(--color-success-soft);
  }
  .icon[data-tone="succeeded"]::after {
    width: 22px;
    height: 12px;
    border-left: 3px solid var(--color-success);
    border-bottom: 3px solid var(--color-success);
    transform: translateY(-2px) rotate(-45deg);
  }
  .icon[data-tone="processing"] {
    background: var(--color-warning-soft);
  }
  .icon[data-tone="processing"]::after {
    width: 18px;
    height: 18px;
    border: 3px solid color-mix(in srgb, var(--color-warning) 30%, transparent);
    border-top-color: var(--color-warning);
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }
  .icon[data-tone="failed"] {
    background: var(--color-danger-soft);
  }
  .icon[data-tone="failed"]::after {
    content: "×";
    color: var(--color-danger);
    font-size: 2rem;
    line-height: 1;
    font-weight: 700;
  }
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }
  h1 {
    font-weight: 600;
    font-size: var(--text-2xl);
    margin: 0 0 0.5rem;
  }
  .message {
    color: var(--color-ink-500);
    margin: 0 0 1.5rem;
    font-size: var(--text-sm);
  }
  .subnote {
    margin: -0.75rem 0 1.5rem;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-success);
    background: var(--color-success-soft);
    border-radius: var(--radius-sm);
    padding: 0.625rem 0.875rem;
    font-variant-numeric: tabular-nums;
  }
  .note {
    text-align: left;
    font-size: var(--text-sm);
    color: var(--color-ink-500);
    background: var(--color-ink-100);
    border-radius: var(--radius-md);
    padding: 1rem 1.1rem;
    margin: 0 0 1.5rem;
    line-height: 1.65;
  }
  .webhook__caption {
    margin: 0.6rem 0 1.5rem;
    font-size: var(--text-xs);
    color: var(--color-ink-400, #8792a2);
  }
  .webhook {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    padding: 0.5rem 0.875rem;
    border-radius: 999px;
    font-size: var(--text-sm);
    font-weight: 500;
    background: var(--color-ink-100);
    color: var(--color-ink-700);
  }
  .webhook__dot {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    background: var(--color-ink-400, #8792a2);
    flex-shrink: 0;
  }
  /* waiting: amber, with a spinner so the polling is visible */
  .webhook[data-state="waiting"] {
    background: var(--color-warning-soft);
    color: var(--color-warning);
  }
  .webhook[data-state="waiting"] .webhook__dot {
    width: 0.85rem;
    height: 0.85rem;
    background: transparent;
    border: 2px solid color-mix(in srgb, var(--color-warning) 30%, transparent);
    border-top-color: var(--color-warning);
    animation: spin 0.7s linear infinite;
  }
  /* received: green, solid */
  .webhook[data-state="received"] {
    background: var(--color-success-soft);
    color: var(--color-success);
  }
  .webhook[data-state="received"] .webhook__dot {
    background: var(--color-success);
  }
  .btn {
    display: inline-block;
    border-radius: var(--radius-md);
    background: var(--color-accent);
    color: #fff;
    font-weight: 600;
    padding: 0.75rem 1.25rem;
    text-decoration: none;
  }
  .btn:hover {
    background: var(--color-accent-strong);
  }
</style>

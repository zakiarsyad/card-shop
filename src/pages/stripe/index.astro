---
import Layout from "../../layouts/Layout.astro";
import { BRAND } from "../../lib/brand";
import DemoIntro from "../../components/stripe/DemoIntro.astro";
import TestCards from "../../components/stripe/TestCards.astro";
import CheckoutShell from "../../components/CheckoutShell.astro";
---

<Layout preconnectStripe provider="stripe" title={`${BRAND.name} — a Stripe checkout demo`}>
  <main class="page">
    <!-- Left: what it is + how to run it -->
    <section class="info" aria-labelledby="demo-title">
      <DemoIntro />
      <TestCards />
    </section>
    
    <!-- Right: the live checkout -->
    <section class="checkout" aria-label="Checkout">
      <CheckoutShell provider="stripe" />
      <a class="readmore" href={`${BRAND.repo}/tree/main/docs`} rel="noopener">
        Source &amp; architecture →
      </a>
    </section>
  </main>

  <script>
    import { initCheckout } from "../../scripts/stripe/checkout";
    initCheckout();
  </script>
</Layout>

<style>
  .page {
    min-height: 100dvh;
    max-width: 900px;
    margin-inline: auto;
    padding: clamp(1.5rem, 5vw, 3rem) clamp(1rem, 4vw, 2rem);
    display: grid;
    gap: clamp(1.75rem, 4vw, 3rem);
  }
  /* Top-aligned so the card grows downward when the Payment Element expands,
     instead of re-centering and pushing the plans/total up. */
  @media (min-width: 860px) {
    .page {
      grid-template-columns: 1fr 400px;
      align-items: start;
    }
  }
  /* The left column owns the spacing between its child components. */
  .info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  /* Cap on a single column so the card doesn't stretch wider than the content
     beside it; on desktop the 400px grid column wins. Owns spacing between the
     card and the source link below it. */
  .checkout {
    width: 100%;
    max-width: 30rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .readmore {
    align-self: center;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-accent-strong);
    text-decoration: none;
  }
  .readmore:hover {
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
